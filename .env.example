# Opcional: reescritura del CV con OpenAI al exportar (useAi=true en el cliente)
OPENAI_API_KEY=
# Ej.: gpt-4o-mini, gpt-4.1-mini
OPENAI_MODEL=gpt-4o-mini

# Opcional: conversión DOCX → PDF (prioridad 1). Ej. http://localhost:3000
GOTENBERG_URL=

# Opcional: conversión DOCX → PDF (prioridad 2). Ruta al binario soffice si no está en PATH
# macOS ejemplo: /Applications/LibreOffice.app/Contents/MacOS/soffice
LIBREOFFICE_PATH=
