# Opcional: vista previa estructurada con IA (/api/improve-preview) y rutas API que llamen a OpenAI
OPENAI_API_KEY=
# Por defecto en código: gpt-4o (rápido y preciso). Más barato: gpt-4o-mini. Más matices: gpt-4.1, etc.
OPENAI_MODEL=gpt-4o

# PDF descargado: mismo DOCX Harvard → PDF vectorial si configuras uno de estos (si no, PDF texto plano).
# Prioridad 1 — Gotenberg (servicio con endpoint /forms/libreoffice/convert)
GOTENBERG_URL=

# Prioridad 2 — LibreOffice en PATH o ruta explícita al binario soffice
# macOS ejemplo: /Applications/LibreOffice.app/Contents/MacOS/soffice
LIBREOFFICE_PATH=
