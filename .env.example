# URL canónica / sitemap / metadata (sin barra final). Por defecto en código: https://ats.rusmadrigal.com
# Opcional en previews de Vercel: https://tu-proyecto-git-main-xxx.vercel.app
NEXT_PUBLIC_SITE_URL=

# Solo si el HTML se sirve en un dominio y la API en otro (mismo error JSON). Producción normal: vacío.
# Ejemplo: https://tu-app.vercel.app
NEXT_PUBLIC_APP_URL=

# Opcional: vista previa estructurada con IA (/api/improve-preview) y rutas API que llamen a OpenAI
OPENAI_API_KEY=
# Id. exacto del modelo en la API de OpenAI para tu cuenta (p. ej. gpt-4o, gpt-4o-mini, gpt-4.1).
# Si pones un nombre que no exista (p. ej. gpt-5.3), la API fallará: no es un problema de clave.
# Por defecto en código: gpt-4o
OPENAI_MODEL=gpt-4o

# PDF descargado: mismo DOCX Harvard → PDF vectorial si configuras uno de estos (si no, PDF texto plano).
# Prioridad 1 — Gotenberg (servicio con endpoint /forms/libreoffice/convert)
GOTENBERG_URL=

# Prioridad 2 — LibreOffice en PATH o ruta explícita al binario soffice
# macOS ejemplo: /Applications/LibreOffice.app/Contents/MacOS/soffice
LIBREOFFICE_PATH=
